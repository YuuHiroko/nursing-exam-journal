{
  "48": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Partograph Monitoring</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Plot cervical dilatation hourly</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Compare to alert line</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Within alert line → Continue</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Alert line crossed → Re-assess</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Action line crossed → Intervene</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Augmentation / Caesarean section</div>\n  </div>\n</div>",
  "49": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Episiotomy Procedure</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Indication identified (FD, breech, forceps)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Infiltrate perineum with lidocaine</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Make mediolateral incision at crowning</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Baby delivered</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Repair in layers: mucosa → muscle → skin</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Perineal care &amp; pain management</div>\n  </div>\n</div>",
  "50": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Pain Relief in Labour</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Labour pain assessed</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Non-pharmacological<br>Breathing / TENS / Massage</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Pharmacological<br>Opioids / Epidural / N₂O</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Monitor maternal &amp; fetal response</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Nursing: vitals, FHR, support, document</div>\n  </div>\n</div>",
  "51": "",
  "52": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: AMTSL — Third Stage</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Baby born — clamp &amp; cut cord</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Oxytocin 10 IU IM within 1 minute</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Await signs of placental separation</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Controlled cord traction (Brandt-Andrews)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Deliver placenta &amp; membranes</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Uterine massage — check completeness</div>\n  </div>\n</div>",
  "53": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Placental Separation</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Signs of separation appear</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Uterus globular, cord lengthens, gush of blood</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Schultze<br>Central separation, fetal surface first</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Matthews Duncan<br>Lateral separation, maternal surface first</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Controlled delivery of placenta</div>\n  </div>\n</div>",
  "54": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Induction of Labour</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Assess Bishop score</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Score &lt;6 (Unfavourable)<br>Cervical ripening — PGE₂ / Misoprostol</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Score ≥6 (Favourable)<br>ARM (Artificial Rupture of Membranes)</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Oxytocin infusion — titrate dose</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Monitor FHR &amp; uterine contractions</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Delivery</div>\n  </div>\n</div>",
  "55": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Fetal Well-Being Monitoring</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Monitor FHR, liquor colour, CTG</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Normal CTG<br>Continue labour</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Suspicious CTG<br>Reposition, O₂, IV fluids</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Pathological CTG<br>Urgent delivery</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Document &amp; escalate as needed</div>\n  </div>\n</div>",
  "56": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Immediate Newborn Care</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Baby born — note time of birth</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Dry, warm, stimulate</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Assess APGAR at 1 &amp; 5 minutes</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">APGAR ≥7 — Routine care</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">APGAR &lt;7 — Clear airway, resuscitate</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Clamp &amp; cut cord</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Initiate breastfeeding — Document</div>\n  </div>\n</div>",
  "57": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Prelabour Signs</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Approaching term (36–40 weeks)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Lightening<br>Head descends; dyspnoea relieved</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Show<br>Mucus plug expelled; pink discharge</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Engagement<br>Widest diameter enters pelvis</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Confirms imminent onset of labour</div>\n  </div>\n</div>",
  "58": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Bishop Score Assessment</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Assess 5 parameters (score 0–3 each)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Dilatation, Effacement, Station, Consistency, Position</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Score &lt;6<br>Unfavourable → Ripen cervix</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Score 6–8<br>Intermediate → ARM</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Score &gt;8<br>Favourable → Induce</div>\n      </div>\n    </div>\n  </div>\n</div>",
  "59": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Stages of Labour</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">1st Stage — Cervical effacement &amp; dilatation<br>Latent: 0–4 cm | Active: 4–10 cm<br>Primi: ~12 h | Multi: ~6 h</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">2nd Stage — Expulsion of fetus<br>Primi: up to 2 h | Multi: up to 1 h</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">3rd Stage — Placental delivery<br>5–30 minutes</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">4th Stage — Immediate postpartum recovery<br>1–2 hours after delivery</div>\n  </div>\n</div>",
  "60": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Cardinal Movements of Labour</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Engagement — head enters pelvic brim</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Descent — downward movement through pelvis</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Flexion — chin on chest</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Internal rotation — occiput to anterior</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Extension — head delivered under pubic arch</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">External rotation (Restitution) — head aligns with shoulders</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Expulsion — anterior then posterior shoulder delivered</div>\n  </div>\n</div>",
  "98": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Physiology of First Stage</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Uterine contractions begin (Braxton Hicks → true)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Cervical effacement (shortening &amp; thinning)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Cervical dilatation (0 → 10 cm)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Forewaters form — bag of membranes</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Presenting part descends</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Cervix fully dilated — 2nd stage begins</div>\n  </div>\n</div>",
  "99": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Signs of First Stage of Labour</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Patient presents with possible labour</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Show (blood-stained mucus)</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Regular uterine contractions</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Rupture of membranes (ROM)</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Confirm: cervical dilatation ≥3 cm</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Admit — begin partograph</div>\n  </div>\n</div>",
  "100": "",
  "101": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Oxytocin Infusion Protocol</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Indication confirmed (induction / augmentation)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Dilute oxytocin in normal saline (10 IU in 500 mL)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Start infusion at low dose (2–4 mIU/min)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Titrate every 30 min to adequate contractions</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">3 contractions/10 min — Maintain dose</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Hyperstimulation / FHR change — Stop infusion</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Monitor FHR, contractions, BP continuously</div>\n  </div>\n</div>",
  "102": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Analgesia Effects on Newborn</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Maternal analgesia / anaesthesia administered</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Opioids (Pethidine)<br>Neonatal respiratory depression</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Epidural<br>Fetal bradycardia (maternal hypotension)</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">General anaesthesia<br>Neonatal CNS &amp; respiratory depression</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Assess APGAR — Naloxone if opioid-induced apnoea</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Resuscitate as needed — Monitor temperature</div>\n  </div>\n</div>"
}