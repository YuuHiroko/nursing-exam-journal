  "62": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Involution of Uterus</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Immediately Post-Delivery (1kg)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 1 — At Umbilicus</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 7 — Midway to Symphysis</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 14 — Just Above Symphysis</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">6 Weeks — Pelvic Organ (60g)</div>\n  </div>\n</div>",
  "63": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Lochia — Types &amp; Progression</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Lochia Rubra — Day 1–3 (Red)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Lochia Serosa — Day 4–10 (Pink/Brown)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Lochia Alba — Day 10–6 Weeks (White)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Abnormal: Offensive Odour / Heavy Bleeding</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Refer — Suspect Infection / Retained Products</div>\n  </div>\n</div>",
  "64": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Postnatal Exercise Sequence</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Day 1 — Deep Breathing Exercises</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 2 — Foot &amp; Ankle Movements</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 3–5 — Pelvic Floor Exercises</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Week 1 — Abdominal Tightening</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Week 6 — Full Exercise Programme</div>\n  </div>\n</div>",
  "65": "",
  "66": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Health Education — Postnatal Mother</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Assess Mother &amp; Identify Needs</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Nutrition &amp; Rest</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Personal Hygiene</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Breastfeeding</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Danger Signs</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Family Planning</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Follow-up Visit</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Document &amp; Reinforce Teaching</div>\n  </div>\n</div>",
  "67": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Breast Care &amp; Problems Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Assess Breast — Inspect &amp; Palpate</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Engorgement → Frequent Feeds + Warm Compress</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Cracked Nipple → Positioning + Lanolin Cream</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Mastitis → Antibiotics + Continue Feeding</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Monitor Response to Management</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Educate on Prevention &amp; Self-Care</div>\n  </div>\n</div>",
