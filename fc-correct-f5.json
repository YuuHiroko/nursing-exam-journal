  "103": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Physiology of Lactation</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Delivery of Placenta</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Oestrogen/Progesterone Fall</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Prolactin Rises — Milk Synthesis</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Alveoli Produce &amp; Store Milk</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Nipple Stimulation → Oxytocin Release</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Let-Down Reflex → Milk Ejection</div>\n  </div>\n</div>",
  "104": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Lactation Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Early Initiation — Within 1 Hour</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Correct Positioning &amp; Attachment</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Frequent Feeding — 8–12 Times/Day</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Include Night Feeds</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess Signs of Adequate Intake</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Exclusive Breastfeeding for 6 Months</div>\n  </div>\n</div>",
  "105": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Postpartum Psychological Complications</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Postpartum Blues — Day 3–5 (Mild)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Reassurance &amp; Support — Resolves Spontaneously</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Postpartum Depression — Weeks to Months</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Counselling + Antidepressants</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Postpartum Psychosis — Severe (1–2/1000)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Hospitalise + Antipsychotics + Psychiatric Referral</div>\n  </div>\n</div>",
  "106": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Minor Ailments in Puerperium</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Identify Minor Ailment</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Afterpains → Analgesics + Prone Lying</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Constipation → Fluids + High Fibre</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Urinary Problems → Encourage Voiding</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Breast Engorgement → Frequent Feeds</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Monitor — Refer if No Improvement</div>\n  </div>\n</div>",
  "107": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Case Study — Puerperium Nursing Care</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Systematic Assessment — Mrs. Savita</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Identify Priority Nursing Diagnoses</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Implement Immediate Nursing Care</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Provide Health Education</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Evaluate Response to Care</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Discharge Planning &amp; Follow-up</div>\n  </div>\n</div>"
