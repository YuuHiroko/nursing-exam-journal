{
  "2": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Maternal Mortality — Nurse Midwife Role</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Identify Danger Signs in Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess: Bleeding / Seizure / Sepsis</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Direct Causes<br>(PPH, Eclampsia, Sepsis)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Indirect Causes<br>(Anaemia, Heart Disease)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Emergency First Aid &amp; Stabilisation</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Timely Referral to Facility</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Definitive Management at Hospital</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Reduced Maternal Mortality</div>\n  </div>\n</div>",
  "3": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: ANC Schedule (WHO / GoI)</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">1st Visit — Before 12 Weeks (Booking)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">History, Examination, Blood &amp; Urine Tests</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">2nd Visit — 14–26 Weeks</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Review Labs, TT-2, IFA, Anomaly Scan</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">3rd Visit — 28–32 Weeks</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess Foetal Growth, BP, Oedema</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">4th Visit — 36 Weeks Onwards</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Presentation, Pelvic Assessment, Birth Plan</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Delivery Planning &amp; Institutional Referral</div>\n  </div>\n</div>",
  "4": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Safe Motherhood Initiative</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Pre-pregnancy / Preconception Care</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Quality Antenatal Care (4+ Visits)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Skilled Birth Attendant at Delivery</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Emergency Obstetric Care Access</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Postnatal Care (Mother &amp; Newborn)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Family Planning &amp; Birth Spacing</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Safe Motherhood &amp; Healthy Outcome</div>\n  </div>\n</div>",
  "5": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Reproductive Health Continuum</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Preconception Care &amp; Counselling</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Antenatal Care (1st–3rd Trimester)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Intranatal Care — Safe Delivery</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Postnatal Care (Mother)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Newborn Care (Child)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Family Planning &amp; Well-Woman Care</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Optimal Women's &amp; Child Health</div>\n  </div>\n</div>",
  "6": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Partograph — Use &amp; Interpretation</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Begin Partograph in Active Labour (≥4 cm)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Plot: Cervical Dilation, Foetal Descent</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Record: FHR, Contractions, Vitals, Liquor</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Plot on Alert Line (1 cm/hr expected)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Progress Left of Alert Line — Normal Labour</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Reaches Alert Line — Augment / Refer</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Crosses Action Line → Immediate Intervention</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Safe Delivery / Prevent Obstructed Labour</div>\n  </div>\n</div>",
  "10": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Skilled Birth Attendant (SBA) Role</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Trained SBA Present at Every Birth</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Monitor Labour with Partograph</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Conduct Clean &amp; Safe Delivery</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Active Management of 3rd Stage (AMTSL)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Complication Detected — PPH / Sepsis</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Normal — Postnatal Monitoring</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">First Aid &amp; Emergency Referral if Needed</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Reduced Maternal &amp; Neonatal Mortality</div>\n  </div>\n</div>",
  "11": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Maternal Mortality — Causes &amp; Prevention</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Maternal Death (Death During Pregnancy / 42 Days)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Direct Causes<br>PPH, Eclampsia, Sepsis, Abortion</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Indirect Causes<br>Anaemia, Malaria, Heart Disease</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Three Delays Model (Recognition, Reaching, Receiving care)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Prevention: Quality ANC + SBA + EmOC</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Role of Nurse: Early Detection &amp; Referral</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Sustainable Development Goal — MMR &lt;70/lakh</div>\n  </div>\n</div>",
  "14": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Menstrual Cycle</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Menstruation (Day 1–5)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Follicular Phase (Day 1–13)<br><small>FSH → follicle growth → oestrogen rise</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Ovulation (Day 14)<br><small>LH surge → Graafian follicle ruptures</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Luteal Phase (Day 15–28)<br><small>Corpus luteum → progesterone</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">No Fertilization<br><small>Corpus luteum degenerates → menstruation</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Fertilization occurs<br><small>HCG maintains corpus luteum → pregnancy</small></div>\n      </div>\n    </div>\n  </div>\n</div>",
  "15": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Fertilization</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Sperm deposited in vagina</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Capacitation in female tract<br><small>Sperm gains fertilizing ability</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Sperm reaches ampulla of fallopian tube</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Acrosome reaction<br><small>Enzymes dissolve zona pellucida</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Sperm penetrates ovum</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Cortical reaction<br><small>Blocks polyspermy</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Pronuclei fusion (syngamy)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Zygote formed (2n) → Cleavage begins</div>\n  </div>\n</div>",
  "16": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Fetal Circulation</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Oxygenated blood from placenta<br><small>via umbilical vein</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Ductus venosus<br><small>bypasses fetal liver → IVC</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Right atrium</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Foramen ovale<br><small>→ Left atrium → Left ventricle → Aorta</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Right ventricle → Pulmonary artery<br><small>→ Ductus arteriosus → Aorta</small></div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Systemic circulation (body tissues)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Deoxygenated blood → umbilical arteries → placenta</div>\n  </div>\n</div>",
  "17": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Functions of Placenta</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Placenta</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Nutritive<br><small>Glucose, amino acids, fats to fetus</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Respiratory<br><small>O₂ to fetus; CO₂ removed</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Excretory<br><small>Urea, bilirubin removed</small></div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Endocrine<br><small>HCG, HPL, oestrogen, progesterone</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Protective<br><small>Partial barrier to pathogens</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Immunological<br><small>IgG transfer → passive immunity</small></div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Fetal growth and development ensured</div>\n  </div>\n</div>",
  "19": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Oogenesis &amp; Ovulation</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Oogonium (fetal ovary)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Primary oocyte<br><small>Arrested at Prophase I</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Primordial follicle → Primary follicle<br><small>FSH stimulation at puberty</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Secondary follicle<br><small>Antrum forms; oestrogen secreted</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Graafian (tertiary) follicle<br><small>LH surge triggers Meiosis I completion</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Ovulation — secondary oocyte released</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Not fertilized<br><small>Oocyte degenerates</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Fertilized → Meiosis II completes → Ovum</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Corpus luteum forms → progesterone</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Corpus albicans (if no pregnancy)</div>\n  </div>\n</div>",
  "21": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Fertilization &amp; Implantation</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Sperm + Secondary oocyte (ampulla)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Fertilization → Zygote (2n)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Cleavage divisions<br><small>Zygote travels along fallopian tube</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Morula (16 cells, day 3–4)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Blastocyst (day 5–6)<br><small>Inner cell mass + trophoblast</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Zona pellucida hatches</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Implantation in endometrium (day 6–10)<br><small>Posterior wall of uterus, upper segment</small></div>\n  </div>\n</div>",
  "22": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Signs &amp; Symptoms of Pregnancy</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Signs &amp; Symptoms of Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Presumptive Signs</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Amenorrhoea, nausea, vomiting</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Breast changes, fatigue</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Urinary frequency, quickening</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Probable Signs</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Uterine enlargement</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Hegar's, Goodell's, Chadwick's signs</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Ballottement, urine pregnancy test</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Positive Signs</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Foetal heart sounds (Doppler/fetoscope)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Foetal movements felt by examiner</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Ultrasound: gestational sac / foetus</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Pregnancy Confirmed</div>\n  </div>\n</div>",
  "23": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Physiological Changes — 1st Trimester</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">First Trimester (0–13 Weeks)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Reproductive System</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Uterus enlarges (pear → orange)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Hegar's, Goodell's, Chadwick's signs</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Leucorrhoea, cervical softening</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Cardiovascular</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Blood volume starts increasing</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Heart rate rises ~10 bpm</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">BP slightly falls (vasodilation)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">GI / Metabolic</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Nausea, vomiting (hCG peak)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Increased appetite / food aversions</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Constipation (progesterone effect)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Foetal Organogenesis Complete by 13 Weeks</div>\n  </div>\n</div>",
  "24": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Physiological Changes — Antenatal Period</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Physiological Changes in Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Cardiovascular</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Blood volume ↑ 40–50%</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Cardiac output ↑, BP ↓ mid-trimester</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Respiratory</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Tidal volume ↑, RR unchanged</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Diaphragm elevated 4 cm</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Renal</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">GFR ↑ 50%, urinary frequency</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Glycosuria may occur normally</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Haematological</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Haemodilution (physiological anaemia)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">WBC rises, hypercoagulable state</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Endocrine / Metabolic</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Insulin resistance ↑ (2nd/3rd trimester)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">BMR ↑ 15–20%</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Musculoskeletal / Skin</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Lordosis, ligament laxity</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Striae, pigmentation changes</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Adaptations Support Foetal Growth &amp; Labour</div>\n  </div>\n</div>",
  "25": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Skin Changes During Pregnancy</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Skin Changes in Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Pigmentation Changes</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Linea nigra (midline abdomen)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Chloasma / melasma (face)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Areola darkening (primary/secondary)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Stretch Marks</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Striae gravidarum (abdomen, breasts)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Pink/purple → silver post-delivery</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Vascular Changes</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Spider naevi (oestrogen effect)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Palmar erythema</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Varicose veins, oedema</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Hormone-Driven; Most Resolve Postpartum</div>\n  </div>\n</div>",
  "26": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Cardiovascular Changes in Pregnancy</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Rising Oestrogen &amp; Progesterone</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Peripheral vasodilation</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">SVR falls → BP decreases (2nd trimester)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Plasma volume ↑ 40–50% (by 32 wks)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Stroke volume ↑, HR ↑ 10–15 bpm</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Cardiac output ↑ 30–50% (peaks 28–32 wks)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Supine hypotension: IVC compression</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Physiological anaemia (haemodilution)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Returns to Baseline 6 Weeks Postpartum</div>\n  </div>\n</div>",
  "27": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: History Taking / Booking Visit</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Patient Arrives for Booking Visit</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Identification: Name, age, address, registration</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Chief complaint &amp; LMP / EDD calculation</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Obstetric history (G/P/A/L)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Medical, surgical &amp; family history</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">General &amp; obstetric physical examination</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Investigations: Hb, blood group, urine, USG</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Risk stratification (low / high risk)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Individualised ANC Plan &amp; Counselling</div>\n  </div>\n</div>",
  "28": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Importance of Antenatal Care</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Early Registration (&lt;12 Weeks)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Baseline assessment: history, examination, investigations</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Risk identification (anaemia, HTN, GDM, infections)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Low Risk</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Routine ANC schedule (4–8 visits)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Health education, supplements, immunisation</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">High Risk</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Enhanced monitoring &amp; referral</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Specialist care, hospital delivery</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Monitoring: foetal growth, maternal well-being</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Safe Delivery &amp; Healthy Mother &amp; Baby</div>\n  </div>\n</div>",
  "29": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Booking Visit — ANC Process</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">First ANC Contact (&lt;12 Weeks Ideal)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Registration &amp; consent</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Complete history (obstetric, medical, family)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">General &amp; obstetric examination</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Investigations: Hb, ABO/Rh, urine R/M, VDRL, HIV, USG</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Supplements: IFA, calcium, folic acid</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">TT immunisation &amp; birth preparedness</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Health education &amp; diet counselling</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">ANC Card Issued; Next Visit Scheduled</div>\n  </div>\n</div>",
  "30": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: ANC Schedule / Visits</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Pregnancy Confirmed</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Visit 1 — Before 12 weeks (booking)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Visit 2 — 14–16 weeks (anomaly screening)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Visit 3 — 28 weeks (GDM screen, TT-2, growth)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Visit 4 — 32 weeks (presentation, anaemia recheck)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Visit 5 — 36 weeks (engagement, birth plan)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Visit 6 — 40 weeks (post-dates assessment)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Birth Preparedness &amp; Safe Delivery Plan</div>\n  </div>\n</div>",
  "32": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Minor Ailments of Pregnancy by Trimester</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Minor Ailments of Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">1st Trimester</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Nausea &amp; vomiting (morning sickness)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Urinary frequency, fatigue</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Breast tenderness, heartburn</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">2nd Trimester</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Constipation, flatulence</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Backache, round ligament pain</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Leucorrhoea, leg cramps</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">3rd Trimester</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Oedema, varicose veins</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Dyspnoea, insomnia</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Haemorrhoids, urinary frequency</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Managed with Education, Lifestyle &amp; Symptomatic Relief</div>\n  </div>\n</div>",
  "34": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Management of Nausea &amp; Vomiting in Pregnancy</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Nausea &amp; Vomiting in Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess severity: mild / moderate / severe (hyperemesis)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Mild–Moderate</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Small frequent meals; avoid triggers</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Ginger, dry crackers, cold fluids</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Pyridoxine (Vit B6) ± antiemetic</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Hyperemesis Gravidarum</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Hospitalise; IV fluids (N/S or RL)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">IV antiemetics (ondansetron, metoclopramide)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Correct electrolyte imbalance</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Thiamine supplementation</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Monitor Weight, Hydration &amp; Foetal Well-Being</div>\n  </div>\n</div>"
}