{
  "35": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Gestational Diabetes Mellitus Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Screen All Pregnant Women at 24–28 Weeks</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">GCT: 50 g glucose → plasma glucose at 1 hr</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">GCT &lt;140 mg/dL → Routine ANC</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">GCT ≥140 mg/dL → OGTT (75 g / 100 g)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">GDM Diagnosed (IADPSG / ADA criteria)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Medical nutrition therapy + exercise (2 weeks)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Targets met → Continue diet therapy</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Targets not met → Insulin therapy</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Monitoring: FBS, PPBS, foetal growth scans</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Delivery plan: 38–39 weeks (or earlier if indicated)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Postpartum OGTT at 6 weeks</div>\n  </div>\n</div>",
  "36": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Pre-eclampsia Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">BP ≥140/90 mmHg after 20 Weeks + Proteinuria</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Mild Pre-eclampsia</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Hospitalise; bed rest (left lateral)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Antihypertensives (methyldopa / labetalol)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Foetal monitoring; daily urine protein</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Deliver at 37 weeks</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Severe Pre-eclampsia</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">ICU / HDU admission</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">IV labetalol / hydralazine / nifedipine</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">MgSO₄ (seizure prophylaxis)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Deliver at 34 weeks (or immediately)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Eclampsia: ABC + MgSO₄ + Emergency Delivery</div>\n  </div>\n</div>",
  "37": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Nutritional Assessment / MUAC</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Nutritional Assessment in Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">MUAC measurement (non-dominant arm)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">MUAC ≥23 cm</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Normal nutritional status</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Routine diet counselling</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">MUAC 21–22.9 cm</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Moderate undernutrition</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Dietary supplementation + monitoring</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">MUAC &lt;21 cm</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Severe acute malnutrition</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Refer; therapeutic nutrition support</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Reassess Monthly; Optimise Foetal Growth</div>\n  </div>\n</div>",
  "38": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Iron Deficiency Anaemia in Pregnancy</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Screen Hb at Booking, 28 &amp; 36 Weeks</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Hb ≥11 g/dL → Prophylactic IFA daily</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Hb 7–10.9 g/dL → Mild/Moderate anaemia</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Hb &lt;7 g/dL → Severe anaemia</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Mild–Moderate</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Oral ferrous sulphate 200 mg TDS</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Folic acid + Vit C; diet counselling</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Recheck Hb after 4 weeks</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Severe</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Hospitalise; IV iron sucrose</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Blood transfusion if Hb &lt;6 g/dL</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Managed delivery in hospital</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Target Hb ≥11 g/dL Before Delivery</div>\n  </div>\n</div>",
  "56": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Uterotonic Drugs in Third Stage</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Uterotonic / Oxytocic Drugs</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Oxytocin</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">10 IU IM / IV infusion</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Stimulates uterine contraction</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Ergometrine</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">0.2 mg IM / IV</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Sustained tonic contraction</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Misoprostol</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">600 mcg oral / sublingual</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Prostaglandin E1 analogue</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Carboprost</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">250 mcg IM every 15 min</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Prostaglandin F2α analogue</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Prevention &amp; Treatment of PPH</div>\n  </div>\n</div>",
  "57": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Retained Placenta Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Placenta not delivered &gt;30 min</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">IV access + IV oxytocin infusion</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess: bladder empty, cord intact</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Controlled cord traction (CCT)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Placenta delivered?</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Yes → Monitor &amp; complete care</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">No → Manual removal under anaesthesia</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">IV antibiotics post-procedure</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Monitor for PPH &amp; infection</div>\n  </div>\n</div>",
  "58": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Perineal Repair Procedure</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Assess perineal tear / episiotomy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Classify degree (1st–4th)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Administer local anaesthesia</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Repair vaginal mucosa (continuous suture)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Repair perineal muscle layer</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Repair perineal skin (subcuticular)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Rectal examination to confirm integrity</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Post-repair: analgesia &amp; hygiene care</div>\n  </div>\n</div>",
  "59": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Shoulder Dystocia Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Head delivered — body not following</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Call for help immediately</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">McRoberts manoeuvre (hyperflexion of thighs)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Suprapubic pressure (Rubin I)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Delivery of posterior arm</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Internal rotational manoeuvres (Rubin II / Woods screw)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Last resort: deliberate clavicle fracture / Zavanelli</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Deliver baby — neonatal resuscitation ready</div>\n  </div>\n</div>",
  "60": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Uterine Rupture Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Suspect uterine rupture</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Sudden severe abdominal pain + shock</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Call senior obstetrician + team</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">2 large-bore IV lines + fluid resuscitation</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Cross-match blood + consent for surgery</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Emergency laparotomy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Repair rupture (uterine conservation)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Hysterectomy (uncontrolled bleeding)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">ICU monitoring + antibiotics post-op</div>\n  </div>\n</div>",
  "62": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Involution of Uterus</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Immediately Postpartum<br><small>1000g, at umbilicus</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 1: 1 cm above umbilicus<br><small>Uterus rises briefly</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 3: 3 cm below umbilicus<br><small>~750g, lochia rubra</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 7: Midway symphysis-umbilicus<br><small>~500g, lochia serosa</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 14: Behind pubic symphysis<br><small>~350g, lochia alba</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Week 6: Pre-pregnant size<br><small>~60g, involution complete</small></div>\n  </div>\n</div>",
  "64": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Postnatal Exercises Progression</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Day 1–2: Breathing &amp; foot exercises<br><small>Deep breathing, ankle circles</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Day 3–7: Pelvic floor exercises<br><small>Kegel, abdominal tightening</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Week 2: Gentle abdominal exercises<br><small>Head lifts, leg slides</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Week 4: Pelvic tilts &amp; bridges<br><small>Core strengthening begins</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Week 6: Full exercise resumption<br><small>Cleared at postnatal check</small></div>\n  </div>\n</div>",
  "66": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Management of Puerperal Pyrexia</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Temp &gt;38°C after 24 hrs postpartum</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Identify cause<br><small>UTI, mastitis, wound, DVT, endometritis</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Investigations<br><small>CBC, urine/wound/blood culture, USG</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Medical treatment<br><small>Appropriate antibiotics, antipyretics</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Nursing care<br><small>Hydration, hygiene, vitals monitoring</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Monitor &amp; prevent complications<br><small>Septicaemia, peritonitis, DVT</small></div>\n  </div>\n</div>",
  "67": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Management of Mastitis &amp; Breast Abscess</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Early mastitis: pain, redness, fever</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Continue breastfeeding / expression<br><small>Empty breast, warm compresses</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Antibiotics (Cloxacillin/Flucloxacillin)<br><small>Analgesics, rest, hydration</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Resolves<br><small>Continue feeding, complete antibiotics</small></div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Abscess forms<br><small>Fluctuant swelling, high fever</small></div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Surgical incision &amp; drainage<br><small>Stop feeding affected side</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Prevention<br><small>Correct latch, nipple care, hygiene</small></div>\n  </div>\n</div>",
  "68": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Breastfeeding Technique</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Comfortable maternal positioning<br><small>Cradle / cross-cradle / football hold</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Correct infant attachment<br><small>Wide mouth, areola covered, chin touches breast</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Rooting &amp; suck-swallow reflex<br><small>Baby actively feeding</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Let-down reflex triggered<br><small>Oxytocin release, milk ejection</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Signs of adequate feeding<br><small>8–12 feeds/day, wet nappies, weight gain</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Burping &amp; safe positioning after feed</div>\n  </div>\n</div>",
  "69": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Management of Postpartum Depression</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Screen all mothers with EPDS<br><small>Score &gt;10 = at risk</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Postnatal Blues (Day 3–5)<br><small>Reassurance, support, watchful waiting</small></div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Mild–Moderate PPD<br><small>Counselling, CBT, social support</small></div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Severe PPD<br><small>Antidepressants (SSRIs) + psychiatry referral</small></div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Nursing care<br><small>Empathy, education, involve partner/family</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Follow-up &amp; relapse prevention</div>\n  </div>\n</div>",
  "71": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Immediate Care of Newborn at Birth</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Baby Delivered</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Dry &amp; Warm (radiant warmer)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Clear Airway (suction mouth, nose)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess Breathing &amp; APGAR Score</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Clamp &amp; Cut Umbilical Cord</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Skin-to-Skin &amp; Eye Care (erythromycin)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Vitamin K 1 mg IM</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Initiate Breastfeeding (within 1 hr)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Identify, Tag &amp; Document</div>\n  </div>\n</div>",
  "72": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Neonatal Head-to-Toe Assessment</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">General Appearance &amp; Vitals</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Head — Fontanelles, Sutures, Shape</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Eyes, Ears, Nose, Mouth (EENT)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Neck &amp; Clavicles (fracture check)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Chest — Breath Sounds, Heart Sounds</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Abdomen — Cord, Organs, Anus Patency</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Genitalia &amp; Spine</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Extremities — Tone, Digits, Hips</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Neurological — Reflexes (Moro, Rooting)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Document &amp; Report Abnormalities</div>\n  </div>\n</div>",
  "73": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: APGAR Score &amp; Action</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Assess at 1 &amp; 5 Minutes</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Score 5 Signs (0–2 each): HR, RR, Tone, Reflex, Colour</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Score 0–3 (Severe Depression)</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Score 4–6 (Moderate Depression)</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Score 7–10 (Normal)</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Immediate Resuscitation (PPV, Intubation)</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Stimulate, O&#x2082;, Reassess at 5 min</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Routine Newborn Care</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Document Score &amp; Outcome</div>\n  </div>\n</div>",
  "74": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: WHO 10 Steps to Successful Breastfeeding</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Step 1: Written BF Policy in Facility</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Step 2: Train All Healthcare Staff</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Step 3: Inform Pregnant Women of BF Benefits</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Step 4: Skin-to-Skin &amp; BF within 1 Hour</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Step 5: Show Mothers How to Breastfeed</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Step 6: Give Only Breast Milk (no supplements)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Step 7: Rooming-In 24 Hours/Day</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Step 8: Breastfeed on Demand</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Step 9: No Artificial Teats or Pacifiers</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Step 10: Refer to BF Support Groups on Discharge</div>\n  </div>\n</div>",
  "75": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Neonatal Sepsis &amp; Cord Care Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Suspect Sepsis (Lethargy, Poor Feed, Fever/Hypothermia)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Investigations: CBC, CRP, Blood Culture</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Early-Onset Sepsis (&lt;72 hrs)</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Late-Onset Sepsis (&gt;72 hrs)</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">IV Antibiotics (Ampicillin + Gentamicin)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Supportive Care: IV Fluids, O&#x2082;, Warmth</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Cord Care: Dry Method, Clean &amp; Dry (no spirit)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Fold Nappy Below Cord Stump</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Monitor &amp; Cord Falls Off in 7–10 Days</div>\n  </div>\n</div>",
  "76": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Neonatal Jaundice Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Jaundice Detected in Neonate</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess Onset, Duration &amp; Serum Bilirubin</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Physiological (Day 2–3, resolves &lt;2 wks)</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Pathological (Day 1, prolonged/severe)</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Frequent Breastfeeding &amp; Monitor</div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Investigate Cause (Rh/ABO, Infection)</div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Phototherapy (Bilirubin above threshold)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Exchange Transfusion (if critically high)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Monitor Bilirubin &amp; Prevent Kernicterus</div>\n  </div>\n</div>",
  "77": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Developmental Milestones by Age</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Birth–1 Month: Reflexes, Fixes Gaze</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">3 Months: Holds Head, Social Smile</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">6 Months: Sits with Support, Babbles</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">9 Months: Stands with Support, Pincer Grip</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">12 Months: Walks, 2–3 Words, Cup Drinks</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">18 Months: Runs, 10+ Words, Feeds Self</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">2 Years: Sentences, Climbs, Parallel Play</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">5 Years: Hops, Draws, School-Ready</div>\n  </div>\n</div>",
  "79": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Family Planning Methods</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Family Planning Methods</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Temporary Methods</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Permanent Methods</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Emergency Methods</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Barrier / Hormonal / IUCD</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Vasectomy / Tubectomy</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">ECP / Cu-IUCD</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Appropriate Method Selected &amp; Counselled</div>\n  </div>\n</div>",
  "80": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Contraception Counselling Process</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Client Presents for Counselling</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Take Detailed History</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess Reproductive Goals</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Discuss All Available Methods</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Identify Contraindications</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assist in Informed Choice</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Demonstrate Correct Usage</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Schedule Follow-up Visit</div>\n  </div>\n</div>"
}
