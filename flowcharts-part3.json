{
  "81": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Oral Contraceptive Pills</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Oral Contraceptive Pills (OCPs)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Combined Pill (Estrogen + Progestin)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Mini-Pill (Progestin Only)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Emergency Pill (ECP)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Mechanism: Inhibit Ovulation / Thicken Cervical Mucus</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Side Effects: Nausea / Headache / Spotting</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Nursing: Educate, Monitor BP, Ensure Compliance</div>\n  </div>\n</div>",
  "82": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: IUCD Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Client Seeking IUCD</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Counselling &amp; Informed Consent</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Rule Out Contraindications</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Optimal Timing: Post-Menstrual / Post-Partum</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Aseptic IUCD Insertion</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Post-Insertion Instructions Given</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Follow-up at 6 Weeks</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Removal on Request / Expiry</div>\n  </div>\n</div>",
  "83": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Barrier Methods of Contraception</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Barrier Methods</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Male Barrier</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Female Barrier</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Chemical Barrier</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Male Condom / Diaphragm</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Female Condom / Cervical Cap</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Spermicides</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Mechanism: Block Sperm Entry</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Prevents Fertilisation / STI Protection</div>\n  </div>\n</div>",
  "84": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Vasectomy vs Tubectomy</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Permanent Sterilisation Decision</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Male → Vasectomy</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Female → Tubectomy</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Vas Deferens Cut / Ligated</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Fallopian Tubes Cut / Ligated</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">OPD / Local Anaesthesia</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Laparoscopy / Mini-laparotomy</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Permanent Prevention of Fertilisation</div>\n  </div>\n</div>",
  "85": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Emergency Contraception Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Unprotected Intercourse / Contraception Failure</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Within 72 Hours</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Within 5 Days</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Emergency Contraceptive Pill (Levonorgestrel)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Cu-IUCD Insertion</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Mechanism: Delay / Inhibit Ovulation</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Counsel on Regular Contraception</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Follow-up if Period Delayed &gt;1 Week</div>\n  </div>\n</div>",
  "86": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Population Explosion</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Population Explosion</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Causes: High Birth Rate / Low Death Rate / Early Marriage</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Effects: Poverty / Unemployment / Malnutrition</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Strain on Health / Education / Resources</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Promote Family Planning</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Female Education &amp; Empowerment</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Government Policies (NHP)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Controlled Population Growth</div>\n  </div>\n</div>",
  "87": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: National Family Planning Programme</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">National Family Planning Programme (1952)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Spacing Methods (IUCD / OCPs)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Terminal Methods (Sterilisation)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Basket of Choices</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Primary Level (PHC / Sub-centre)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Secondary Level (CHC / District)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Tertiary Level (Medical College)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">IEC Activities &amp; ASHA Mobilisation</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Achieve NRR = 1 (Replacement Level Fertility)</div>\n  </div>\n</div>",
  "88": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Janani Suraksha Yojana (JSY)</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Pregnant Woman Registers Under JSY</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Eligibility: BPL / SC / ST / Rural / Low-Performing State</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">ANC Registration &amp; ASHA Linkage</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Institutional Delivery at Govt / Accredited Facility</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Cash Benefit to Mother</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Incentive to ASHA Worker</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Post-Natal Care &amp; Follow-up</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Reduced MMR &amp; Safe Motherhood</div>\n  </div>\n</div>",
  "90": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Amniotic Fluid</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Amniotic Fluid</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Sources<br><small>Fetal urine (main), lung fluid, amnion, fetal skin (early)</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Functions<br><small>Cushions fetus, maintains temp, permits movement, prevents adhesions</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Normal Volume<br><small>500–1000 mL at term</small></div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assessment Methods</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">AFI (Amniotic Fluid Index)<br><small>Normal 8–18 cm</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Single Deepest Pocket<br><small>Normal 2–8 cm</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Amniocentesis<br><small>Cytology, biochemistry</small></div>\n      </div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box\">Polyhydramnios<br><small>AFI &gt;18 cm; GDM, fetal anomalies</small></div>\n      </div>\n      <div class=\"flow-branch-item\">\n        <div class=\"flow-branch-line\"></div>\n        <div class=\"flow-box highlight\">Oligohydramnios<br><small>AFI &lt;5 cm; renal agenesis, IUGR</small></div>\n      </div>\n    </div>\n  </div>\n</div>",
  "91": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Estimation of Gestational Age</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Estimate Gestational Age</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">LMP (Naegele's Rule)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">LMP + 9 months + 7 days = EDD</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Reliable if regular cycles &amp; known LMP</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Ultrasonography</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">1st trimester: CRL (most accurate)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">2nd trimester: BPD / FL / AC</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Fundal Height</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Symphysis → fundus (cm ≈ weeks ±2)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Reliable 20–36 weeks</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Ballard Score (Neonate)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Neuromuscular + physical maturity criteria</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Post-delivery gestational age estimation</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Confirmed EDD &amp; Delivery Planning</div>\n  </div>\n</div>",
  "92": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Fundal Height Measurement</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Patient in Dorsal Recumbent Position</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Empty bladder confirmed</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Locate symphysis pubis (lower fixed point)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Palpate uterine fundus (upper point)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Measure with tape (cm) symphysis → fundus</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">cm ≈ weeks of gestation (±2 cm)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Small for dates → IUGR / oligohydramnios?</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Large for dates → Twins / polyhydramnios?</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Document on Growth Chart; Refer if Abnormal</div>\n  </div>\n</div>",
  "95": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Leucorrhoea in Pregnancy — Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Vaginal Discharge in Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess: colour, odour, consistency, pruritus</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Physiological Leucorrhoea</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">White, non-offensive, mild</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Reassurance + hygiene education</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Cotton underwear; avoid douching</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Pathological (Infection)</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Swab culture: BV / Candida / Trichomonas</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">BV → metronidazole; Candida → clotrimazole</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Treat partner if STI suspected</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Resolve Infection; Monitor for Preterm Labour Risk</div>\n  </div>\n</div>",
  "96": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Varicose Veins in Pregnancy — Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Varicose Veins Identified in Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess site: legs / vulva / haemorrhoids</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Non-pharmacological measures</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Elevate legs when resting</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Elastic compression stockings</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Avoid prolonged standing</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Avoid tight clothing; exercise (walking)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Cold compresses for vulval varicosities</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Monitor for thrombophlebitis / DVT signs</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Most Resolve Spontaneously Postpartum</div>\n  </div>\n</div>",
  "97": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Constipation in Pregnancy — Management</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Constipation Reported in Pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Causes: progesterone → gut motility ↓; iron supplements</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Dietary measures</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">High-fibre diet (fruits, vegetables, bran)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Adequate fluid intake (2–3 L/day)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Regular light exercise (walking)</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Regular bowel habits; respond to urge promptly</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">If refractory → ispaghula husk (safe laxative)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Avoid stimulant laxatives in pregnancy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Relief Achieved; Prevent Haemorrhoids</div>\n  </div>\n</div>",
  "98": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Induction of Labour Methods</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Decision to induce labour</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assess Bishop score</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Unfavourable cervix → Prostaglandins (PGE2 gel / Misoprostol)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Favourable cervix → Proceed to ARM</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Artificial rupture of membranes (ARM)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Oxytocin IV infusion (titrated)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Continuous fetal monitoring (CTG)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Vaginal delivery or LSCS if failed</div>\n  </div>\n</div>",
  "99": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Caesarean Section Nursing Care</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Pre-operative Care</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Informed consent + investigations</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">NPO, IV line, catheterisation, shave prep</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Anaesthesia (spinal / general)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Intra-operative Care</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Monitor vitals + fetal heart rate</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Assist surgeon + neonatal team ready</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Post-operative Care</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Vitals, uterine tone, wound, catheter output</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Analgesia, ambulation, breastfeeding support</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Discharge with wound care instructions</div>\n  </div>\n</div>",
  "100": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Forceps Delivery Process</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Indication confirmed for forceps</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Check prerequisites (fully dilated, engaged, membranes ruptured)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Adequate analgesia / pudendal block</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Episiotomy performed</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Apply forceps blades (left then right)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Traction with contractions (Pajot's manoeuvre)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Deliver head, remove forceps</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Check for perineal / cervical trauma</div>\n  </div>\n</div>",
  "101": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Vacuum Extraction Process</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Indication confirmed for ventouse</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Prerequisites met (fully dilated, engaged head)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Select cup size; apply to flexion point</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Create negative pressure (0.2 → 0.8 kg/cm²)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Traction with contractions + maternal pushing</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Maximum 3 pulls / 3 detachments rule</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Release suction; deliver head</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Assess neonate for cephalhaematoma / trauma</div>\n  </div>\n</div>",
  "102": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Bishop Score Classification</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Assess Cervix (Bishop Score)</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Parameters: Dilation, Effacement, Station, Consistency, Position</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Score 0–4: Unfavourable cervix</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">Cervical ripening required (PGE2 / Misoprostol)</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Score 5–8: Intermediate cervix</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">ARM ± Oxytocin infusion</div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box highlight\">Score &gt;8: Favourable cervix</div><div class=\"flow-arrow\">&darr;</div><div class=\"flow-box\">ARM alone usually sufficient</div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Proceed with induction / monitor progress</div>\n  </div>\n</div>",
  "103": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Management of Puerperal Psychosis</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Acute onset within 2 weeks postpartum<br><small>Delusions, hallucinations, confusion</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Immediate psychiatric assessment<br><small>Risk to mother and baby</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Hospitalisation (Mother &amp; Baby Unit)<br><small>Safe environment, 24-hr observation</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Pharmacotherapy<br><small>Antipsychotics ± mood stabilisers ± antidepressants</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Nursing care<br><small>Safety, hygiene, nutrition, infant bonding support</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Family education &amp; psychotherapy</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Discharge planning &amp; long-term follow-up</div>\n  </div>\n</div>",
  "104": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Management of Secondary PPH</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Secondary PPH: bleeding 24 hrs–6 wks postpartum</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Identify cause<br><small>RPOC, endometritis, coagulation defect</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Investigations<br><small>CBC, coagulation profile, USG pelvis, HVS</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Resuscitation<br><small>IV access, fluids, blood transfusion if needed</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Infection present<br><small>Broad-spectrum antibiotics</small></div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">RPOC on USG<br><small>Surgical evacuation (ERPC)</small></div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Monitor vitals, lochia &amp; haemoglobin</div>\n  </div>\n</div>",
  "105": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Management of Retained Products of Conception</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Suspect RPOC<br><small>Subinvolution, PPH, offensive lochia, fever</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Confirm diagnosis<br><small>USG pelvis: echogenic tissue in uterine cavity</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Stabilise patient<br><small>IV fluids, blood transfusion, antibiotics</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Surgical evacuation (ERPC)<br><small>Under GA; suction/curettage of cavity</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Send specimen for histopathology</div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Post-op care &amp; follow-up USG</div>\n  </div>\n</div>",
  "106": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Perineal Care Process</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Assess perineum after delivery<br><small>Degree of tear / episiotomy</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Clean with warm sterile water<br><small>Front-to-back technique</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Inspect suture line each shift<br><small>Redness, oedema, discharge, dehiscence</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Pain management<br><small>Ice packs, analgesics, sitz bath</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Hygiene education<br><small>Pad change every 4 hrs, hand hygiene</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Healing confirmed &amp; discharge teaching</div>\n  </div>\n</div>",
  "107": "<div class=\"flowchart animate-fade-in\">\n  <div class=\"flowchart-title\">Flowchart: Diagnosis &amp; Management of Subinvolution</div>\n  <div class=\"flowchart-container\">\n    <div class=\"flow-box highlight\">Suspect subinvolution<br><small>Uterus large, soft, lochia persists</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Identify cause<br><small>RPOC, endometritis, fibroids, full bladder</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Investigations<br><small>USG pelvis, HVS, CBC, urine culture</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-branch\">\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">Infection<br><small>Antibiotics (broad-spectrum)</small></div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">RPOC<br><small>Ergometrine + ERPC</small></div></div>\n      <div class=\"flow-branch-item\"><div class=\"flow-branch-line\"></div><div class=\"flow-box\">No clear cause<br><small>Oxytocics / ergometrine course</small></div></div>\n    </div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box\">Encourage breastfeeding<br><small>Stimulates oxytocin, aids involution</small></div>\n    <div class=\"flow-arrow\">&darr;</div>\n    <div class=\"flow-box highlight\">Reassess uterine size at follow-up</div>\n  </div>\n</div>"
}
